# ── Ollama ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Session Settings ─────────────────────────────────────
# Session TTL in milliseconds (86400000 = 24 hours)
SESSION_TTL=86400000

# How often to cleanup expired sessions in milliseconds (86400000 = 24 hours)
SESSION_CLEANUP_INTERVAL=86400000
# Directory where session files are stored (relative to project root)
SESSION_STORAGE_DIR=.sessions
# ── Server (for Stage 2) ─────────────────────────────────
PORT=3000
